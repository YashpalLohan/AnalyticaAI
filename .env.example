# =============================================================
# AnalyticaAI — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================

# -------------------------------------------------------------
# APPLICATION
# -------------------------------------------------------------
APP_NAME=AnalyticaAI
APP_ENV=development           # development | staging | production
APP_PORT=8000
DEBUG=true

# -------------------------------------------------------------
# FRONTEND
# -------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -------------------------------------------------------------
# DATABASE — PostgreSQL
# Free tier: Neon (0.5GB) → https://neon.tech
#            OR Supabase (500MB) → https://supabase.com
# -------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/analytica_ai
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# -------------------------------------------------------------
# REDIS — Queue & Cache
# Free tier: Upstash (10K req/day) → https://upstash.com
# -------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# -------------------------------------------------------------
# AUTHENTICATION — JWT
# -------------------------------------------------------------
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -------------------------------------------------------------
# AI — Groq (LLM inference)
# Get your key at: https://console.groq.com/keys
# -------------------------------------------------------------
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile      # Best quality (128k context)
GROQ_MODEL_FAST=llama-3.1-8b-instant    # Low latency tasks
GROQ_MAX_TOKENS=4096
GROQ_TEMPERATURE=0.2

# -------------------------------------------------------------
# Embeddings — Nomic (Groq does not support embeddings)
# Option A: Nomic API (cloud) — https://atlas.nomic.ai
# Option B: Ollama local — run: ollama pull nomic-embed-text
# -------------------------------------------------------------
NOMIC_API_KEY=                          # Leave blank if using Ollama
EMBEDDING_PROVIDER=ollama               # ollama | nomic_api
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434  # Only needed for Ollama option

# -------------------------------------------------------------
# VECTOR DATABASE — ChromaDB
# -------------------------------------------------------------
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_PATH=./chroma_db

# ChromaDB collection names
CHROMA_COLLECTION_DATASETS=datasets
CHROMA_COLLECTION_CHAT=chat_history
CHROMA_COLLECTION_INSIGHTS=insights
CHROMA_COLLECTION_REPORTS=reports

# -------------------------------------------------------------
# FILE STORAGE — Supabase Storage (free tier: 1GB)
# Get project URL and key at: https://supabase.com/dashboard
# -------------------------------------------------------------
STORAGE_PROVIDER=supabase              # supabase | local
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_STORAGE_BUCKET=analytica-ai

# Storage folder paths (same structure, provider-agnostic)
STORAGE_DATASETS_PREFIX=datasets/
STORAGE_REPORTS_PREFIX=reports/
STORAGE_EXPORTS_PREFIX=exports/
STORAGE_MODELS_PREFIX=models/

# -------------------------------------------------------------
# STORAGE — Local (Development only)
# -------------------------------------------------------------
LOCAL_STORAGE_PATH=./storage
MAX_UPLOAD_SIZE_MB=100

# -------------------------------------------------------------
# SECURITY
# -------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_PER_MINUTE=100
BCRYPT_ROUNDS=12

# -------------------------------------------------------------
# MONITORING & LOGGING
# -------------------------------------------------------------
SENTRY_DSN=
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
ENABLE_REQUEST_LOGGING=true

# -------------------------------------------------------------
# EMAIL (Future — for verification emails)
# -------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@analytica.ai

# -------------------------------------------------------------
# FEATURE FLAGS
# -------------------------------------------------------------
ENABLE_AUTOML=false
ENABLE_FORECASTING=false
ENABLE_ANOMALY_DETECTION=false
ENABLE_WEBSOCKETS=false
